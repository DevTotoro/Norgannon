{
  "name": "api",
  "root": "packages/api",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew build -x test",
        "cwd": "packages/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew test",
        "cwd": "packages/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew ktlintCheck",
        "cwd": "packages/api"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew ktlintFormat",
        "cwd": "packages/api"
      }
    }
  }
}
